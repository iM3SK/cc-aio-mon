#!/usr/bin/env bash
# pre-push hook — scans outgoing commits for obvious secrets and sensitive files.
# Blocks push if matches found. Override only with --no-verify (discouraged).
# Activate per-clone with:  git config core.hooksPath .githooks

set -u

remote="$1"
url="$2"
fail=0

# Read refs being pushed on stdin: <local_ref> <local_sha> <remote_ref> <remote_sha>
while read -r local_ref local_sha remote_ref remote_sha; do
    if [ "$local_sha" = "0000000000000000000000000000000000000000" ]; then
        continue  # deletion
    fi
    if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
        range="$local_sha"  # new branch — scan full history is too broad; scan only tip
    else
        range="$remote_sha..$local_sha"
    fi

    # Changed files across the range
    files=$(git diff --name-only "$range" 2>/dev/null || true)
    [ -z "$files" ] && continue

    # Block sensitive filenames outright
    while IFS= read -r f; do
        case "$f" in
            *.pem|*.key|*.crt|*.p12|credentials.json|.env|.env.*|.envrc|secrets/*|*.log)
                echo "BLOCKED: sensitive file '$f' in push range" >&2
                fail=1
                ;;
        esac
    done <<< "$files"

    # Block obvious credential patterns in diff content (heuristic, not exhaustive)
    diff_text=$(git diff "$range" -- '*.py' '*.sh' '*.ps1' '*.md' '*.yml' '*.yaml' '*.json' 2>/dev/null || true)
    if echo "$diff_text" | grep -qE -- 'sk-ant-[a-zA-Z0-9_-]{20,}'; then
        echo "BLOCKED: Anthropic API key pattern (sk-ant-*) in diff" >&2
        fail=1
    fi
    if echo "$diff_text" | grep -qE -- 'sk-proj-[a-zA-Z0-9_-]{20,}'; then
        echo "BLOCKED: OpenAI API key pattern (sk-proj-*) in diff" >&2
        fail=1
    fi
    if echo "$diff_text" | grep -qE -- 'AKIA[0-9A-Z]{16}'; then
        echo "BLOCKED: AWS Access Key ID pattern in diff" >&2
        fail=1
    fi
    if echo "$diff_text" | grep -qE -- 'ghp_[a-zA-Z0-9]{36}|github_pat_[a-zA-Z0-9_]{40,}'; then
        echo "BLOCKED: GitHub Personal Access Token pattern in diff" >&2
        fail=1
    fi
    if echo "$diff_text" | grep -qE -- '-----BEGIN (RSA|DSA|EC|OPENSSH|PGP) PRIVATE KEY-----'; then
        echo "BLOCKED: Private key block in diff" >&2
        fail=1
    fi
done

if [ "$fail" -ne 0 ]; then
    echo "" >&2
    echo "Push aborted by .githooks/pre-push — review findings above." >&2
    echo "If this is a false positive, run: git push --no-verify (use sparingly)" >&2
    exit 1
fi

exit 0
